
# ============================================================
# VIGIPARL — Template variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# CE fichier peut être commité sur GitHub (pas de vraies clés)
# ============================================================

# --- Légifrance API (PISTE) ---
LEGIFRANCE_CLIENT_ID=your-client-id-here
LEGIFRANCE_CLIENT_SECRET=your-client-secret-here
LEGIFRANCE_TOKEN_URL=https://sandbox-oauth.piste.gouv.fr/api/oauth/token
LEGIFRANCE_API_URL=https://sandbox-api.piste.gouv.fr/dila/legifrance/lf-engine-app

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- PostgreSQL ---
DATABASE_URL=postgresql://vigiparl:vigiparl@localhost:5432/vigiparl

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- FastAPI ---
SECRET_KEY=generate-with-openssl-rand-hex-32
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000